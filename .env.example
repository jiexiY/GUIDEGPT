# Neon Postgres connection created by the Vercel integration.
DATABASE_URL=

# At least 32 random characters. Used only to sign anonymous private sessions.
AUTH_SECRET=

# Optional model override. The default is current, fast, and cost-aware.
AI_MODEL=openai/gpt-5.6-luna

# Canonical public URL used in metadata and extension links.
PUBLIC_APP_URL=https://guidegpt-next.vercel.app
